# Put On My Tab — Environment Variables
# Copy this file to .env.local and fill in your actual values.

# -------------------
# Database Provider
# -------------------
# Supported values: supabase | sqlite | mysql | mongodb
DB_PROVIDER=supabase

# SQLite (used when DB_PROVIDER=sqlite)
# SQLITE_DB_PATH=./data/putonmytab.sqlite

# MySQL (used when DB_PROVIDER=mysql)
# MYSQL_DATABASE_URL=mysql://user:password@localhost:3306/putonmytab

# MongoDB (used when DB_PROVIDER=mongodb)
# MONGODB_URL=mongodb://127.0.0.1:27017/putonmytab

# -------------------
# Supabase
# -------------------
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-publishable-key>
SUPABASE_SECRET_KEY=sb_secret_<your-secret-key>

# -------------------
# NextAuth
# -------------------
NEXTAUTH_URL=http://putonmytab.localhost:3000
NEXTAUTH_SECRET=<generate-with: openssl rand -base64 32>

# -------------------
# UI Preferences
# -------------------
# Currency symbol used in app UI (examples: $, €, £, Rp)
NEXT_PUBLIC_CURRENCY_SYMBOL=$

# -------------------
# OAuth Providers (Phase 2)
# -------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
